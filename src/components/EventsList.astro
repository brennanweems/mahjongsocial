            <div class="flex items-start justify-between mb-3">
              <h3 class="text-2xl font-bold text-gray-900">{event.title}</h3>
              <span class={`px-3 py-1 rounded-full text-sm font-medium ${getDifficultyColor(event.difficulty)}`}>
                {event.difficulty}
              </span>
            </div>
            
