<script>
  // Event signup functionality
  function signUpForEvent(eventId) {
    // In a real application, this would integrate with your backend/payment system
    // For now, we'll show a modal or redirect to a signup form
    
    // Simple modal approach
    const isConfirmed = confirm(`Ready to sign up for this amazing mahjong event?\n\nClick OK to proceed to registration, or Cancel to browse more events.`);
    
    if (isConfirmed) {
      // Redirect to signup form or show modal
      // You could redirect to a dedicated signup page:
      // window.location.href = `/signup?event=${eventId}`;
      
      // Or integrate with a service like Eventbrite, Stripe, or a custom form
      alert(`Great choice! You'll be redirected to our secure registration form.\n\n(In production, this would connect to your payment/registration system)`);
      
      // Example integrations:
      // - Eventbrite: window.open('https://eventbrite.com/your-event-link')
      // - Stripe: initiate checkout session
      // - Custom form: window.location.href = '/register-form'
      // - Email signup: window.location.href = 'mailto:info@mahjongsocialdallas.com?subject=Event Registration'
    }
  }

  // Make function globally available
  (window as any).signUpForEvent = signUpForEvent;
</script>

<style>
  /* Custom styles for the events section */
  
  /* Hover effects for event cards */
  .event-card:hover {
    transform: translateY(-4px);
  }
  
  /* Disabled button styles */
  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
  }
  
  button:disabled:hover {
    background-color: #374151 !important;
    color: white !important;
  }
</style>